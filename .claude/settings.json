{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{
          "type": "command",
          "command": "echo 'CHECK: Design system + RLS rules + route structure correct?'",
          "timeout": 5
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(* next build*)",
        "hooks": [{
          "type": "command",
          "command": "bash scripts/post-build-qa.sh",
          "timeout": 60
        }]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [{
          "type": "command",
          "command": "bash scripts/pre-commit-security.sh",
          "timeout": 30
        }]
      }
    ]
  },
  "permissions": {
    "allow": ["Read", "Write", "Bash", "Glob", "Grep"],
    "deny": ["Bash(sudo *)"]
  }
}
