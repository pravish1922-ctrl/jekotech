{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRE-WRITE CHECK: Ensure design system tokens, relative imports, and RLS rules are followed'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/pre-commit-security.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash",
      "Glob",
      "Grep",
      "Bash(bash scripts/pre-commit-security.sh)"
    ],
    "deny": [
      "Bash(sudo *)"
    ]
  }
}
